    {
      "name": "Dashboard",
      "description": "Aggregated summary data for the dashboard UI. Accessible by all authenticated roles.",
      "item": [
        {
          "name": "Get Dashboard Summary",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has all summary fields', () => {",
                  "  ['total_income','total_expense','net_balance','transaction_count',",
                  "   'income_by_category','expense_by_category','monthly_trends','recent_transactions']",
                  "  .forEach(k => pm.expect(json).to.have.property(k));",
                  "});",
                  "pm.test('Net balance = income - expense', () => {",
                  "  const expected = parseFloat((json.total_income - json.total_expense).toFixed(2));",
                  "  pm.expect(json.net_balance).to.be.closeTo(expected, 0.01);",
                  "});",
                  "pm.test('Monthly trends are sorted', () => {",
                  "  const trends = json.monthly_trends;",
                  "  for (let i = 1; i < trends.length; i++) {",
                  "    const prev = trends[i-1].year * 12 + trends[i-1].month;",
                  "    const curr = trends[i].year * 12 + trends[i].month;",
                  "    pm.expect(curr).to.be.at.least(prev);",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/dashboard/summary",
              "host": ["{{baseUrl}}"],
              "path": ["dashboard", "summary"]
            },
            "description": "Returns:\n- `total_income` / `total_expense` / `net_balance` — all-time totals\n- `transaction_count` — total active records\n- `income_by_category` / `expense_by_category` — sorted by total descending\n- `monthly_trends` — year/month breakdown with income, expense, net\n- `recent_transactions` — last 10 records ordered by date"
          }
        }
      ]
    },
